# ──────────────────────────────────────────────────────────
# AI Subject Matter Expert — Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────

# ── LLM Keys (provide at least one) ──────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...

# ── Primary LLM model override (optional) ────────────────
PRIMARY_LLM=claude-sonnet-4-6

# ── Search APIs (optional — DuckDuckGo is free and needs no key) ─
# Tavily gives better quality results if you have a key
TAVILY_API_KEY=

# ── HuggingFace (only needed to upload dataset) ──────────
HF_TOKEN=hf_...
HF_REPO_ID=your-username/your-subject-sme

# ── Subject Configuration (THE MAIN THING TO CHANGE) ─────
# This defines what subject your SME specializes in
SUBJECT=artificial intelligence
SUBJECT_DESCRIPTION=artificial intelligence, machine learning, and deep learning
SUBJECT_KEYWORDS=artificial intelligence,machine learning,deep learning,neural networks,LLM,transformers,GPT

# ── Research Settings ─────────────────────────────────────
MAX_DOCS_PER_SOURCE=200
MAX_SEARCH_RESULTS=10
RESEARCH_DELAY_MIN=1.0
RESEARCH_DELAY_MAX=3.0

# ── Data Paths (optional — defaults shown) ───────────────
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
VECTOR_DB_DIR=data/vector_db

# ── RAG Settings (optional) ───────────────────────────────
DEFAULT_K_DOCS=5
DEFAULT_K_LEARNINGS=3

# ── Examples for other subjects ───────────────────────────
# SUBJECT=quantum physics
# SUBJECT_DESCRIPTION=quantum mechanics, quantum computing, and quantum field theory
# SUBJECT_KEYWORDS=quantum,entanglement,superposition,qubit,Schrodinger,Heisenberg

# SUBJECT=climate change
# SUBJECT_DESCRIPTION=climate science, global warming, and environmental policy
# SUBJECT_KEYWORDS=climate change,global warming,CO2,greenhouse gas,IPCC,carbon

# SUBJECT=personal finance
# SUBJECT_DESCRIPTION=personal finance, investing, budgeting, and wealth management
# SUBJECT_KEYWORDS=investing,stocks,bonds,ETF,budgeting,savings,retirement,401k
