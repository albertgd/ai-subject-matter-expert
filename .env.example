# ──────────────────────────────────────────────────────────
# AI Subject Matter Expert — Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────

# ── LLM Keys (provide at least one) ──────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...

# ── HuggingFace (optional — only needed to upload dataset) ─
HF_TOKEN=hf_...
HF_REPO_ID=your-username/divorce-cases-en

# ── Primary LLM model override (optional) ────────────────
PRIMARY_LLM=claude-sonnet-4-6

# ── CourtListener API (optional — increases rate limit) ──
COURTLISTENER_API_TOKEN=

# ── Harvard Caselaw Access API (optional) ────────────────
# Register at https://api.case.law to get unrestricted access
CASELAW_API_KEY=

# ── Data paths (optional — defaults shown below) ─────────
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
VECTOR_DB_DIR=data/vector_db

# ── Subject matter configuration ─────────────────────────
# Change these to adapt the SME to a different domain
DOMAIN=divorce
DOMAIN_DESCRIPTION=divorce law and family law proceedings
SEARCH_KEYWORDS=divorce,custody,alimony,child support,marital property,separation agreement

# ── Scraper settings ──────────────────────────────────────
MAX_CASES_PER_SOURCE=500
SCRAPER_DELAY_MIN=1.0
SCRAPER_DELAY_MAX=3.0
